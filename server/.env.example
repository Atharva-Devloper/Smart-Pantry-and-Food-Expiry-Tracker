# Server Configuration
PORT=5000
NODE_ENV=development

# Gemini AI API Key - Get from https://ai.google.dev/
# Sign up and create an API key from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# Database Configuration
# Default is localhost:27017 with database name 'smart-pantry'
# For MongoDB Atlas, use: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGODB_URI=mongodb://localhost:27017/smart-pantry

# JWT Secret - Generate a secure random string for production
# You can generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here_generate_secure_random_string

# CORS Configuration
# Frontend URL - adjust if frontend is running on a different port
CLIENT_URL=http://localhost:5173
